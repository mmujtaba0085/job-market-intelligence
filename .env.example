# Job Market Intelligence - Environment Template

# -----------------------------------------------------------------------------
# Core pipeline behavior
# -----------------------------------------------------------------------------
# true: generate outputs only, skip external publishing side effects
DRY_RUN=true

# -----------------------------------------------------------------------------
# Paths (relative to project root unless absolute)
# -----------------------------------------------------------------------------
DB_PATH=data/jobs.sqlite
AUTH_DB_PATH=data/auth.sqlite
OUTPUTS_DIR=outputs
LOGS_DIR=logs

# -----------------------------------------------------------------------------
# Auth / Security  ← CHANGE THESE BEFORE DEPLOYING
# -----------------------------------------------------------------------------
APP_ENV=production

# A strong random secret for Flask session cookies.
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# Password for the default 'admin' account created on first run.
# Log in immediately after deploy and change it via the admin panel.
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD

# Enable both when the app is served only through the configured HTTPS proxy.
SESSION_COOKIE_SECURE=true
TRUST_PROXY_HEADERS=true

# Security log retention and login throttling use conservative defaults.
ACCESS_LOG_RETENTION_DAYS=90

# -----------------------------------------------------------------------------
# Analytics thresholds
# -----------------------------------------------------------------------------
MIN_FREQ=5
GROWTH_THRESHOLD=20.0
DECLINING_THRESHOLD=-15.0
EMERGING_LOOKBACK_WEEKS=4

# -----------------------------------------------------------------------------
# Collector/source API keys (optional by source)
# -----------------------------------------------------------------------------
# Primary source key (JSearch via RapidAPI)
JSEARCH_API_KEY=

# Optional collectors
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
FINDWORK_API_KEY=
JOOBLE_API_KEY=
USAJOBS_API_KEY=
USAJOBS_USER_AGENT=

# Optional crawler state file override
FINDWORK_CRAWLER_STATE_FILE=

# -----------------------------------------------------------------------------
# AI provider config (Grok/Groq-compatible)
# -----------------------------------------------------------------------------
# Backward-compatible single-key fields
GROQ_API_KEY=
GROK_API_KEY=

# Comma-separated key pool for parallel workers
# Example: GROQ_API_KEYS=key_a,key_b,key_c
GROQ_API_KEYS=

# Model/base URL routing
# If using Groq OpenAI-compatible endpoint:
#   GROK_BASE_URL=https://api.groq.com/openai/v1
# If using xAI Grok endpoint:
#   GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=
GROK_BASE_URL=

# Optional aliases supported by config.settings
GROQ_MODEL=
GROQ_BASE_URL=

# -----------------------------------------------------------------------------
# Web viewer
# -----------------------------------------------------------------------------
WEB_VIEWER_URL=http://localhost:5000
FLASK_SECRET_KEY=change-this-in-production

# -----------------------------------------------------------------------------
# Google Sheets integration
# -----------------------------------------------------------------------------
SHEETS_ENABLED=false
GOOGLE_SA_JSON_PATH=config/job-market-intelligence-489015-57c9087db0cf.json

# Private/edit spreadsheet IDs
SHEETS_CANADA_ID=
SHEETS_UK_ID=
SHEETS_US_ID=

# Published sheet IDs (used for public "publish to web" links)
SHEETS_CANADA_PUBLISHED_ID=
SHEETS_UK_PUBLISHED_ID=
SHEETS_US_PUBLISHED_ID=

# -----------------------------------------------------------------------------
# Tracker spreadsheet integration (click tracking)
# -----------------------------------------------------------------------------
TRACKER_SPREADSHEET_ID=
TRACKER_DEPLOYMENT_BASE_URL=
TRACKER_TOKEN=
